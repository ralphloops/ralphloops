{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralphloops.io/schemas/metadata.schema.json",
  "title": "Ralph Loops frontmatter metadata",
  "description": "JSON Schema for the YAML frontmatter block of a RALPH.md file.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "agent": {
      "type": "string",
      "minLength": 1,
      "description": "The command to run (anything that reads stdin)."
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "run"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Name used in {{ commands.<name> }} template placeholders."
          },
          "run": {
            "type": "string",
            "minLength": 1,
            "description": "Shell command to execute."
          }
        },
        "additionalProperties": false
      },
      "description": "Deterministic feedback commands."
    },
    "args": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "CLI arguments that become --<name> flags and {{ args.<name> }} template variables."
    }
  }
}
